{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^(?!z-paging-refresh|z-paging-load-more)z-paging(.*)": "z-paging/components/z-paging$1/z-paging$1.vue"
    }
  },
  "globalStyle": {
    "navigationBarTitleText": "uniapp-starter",
    "navigationBarBackgroundColor": "@navBgColor",
    "navigationBarTextStyle": "@navTxtStyle",
    "backgroundColor": "@bgColor",
    "backgroundTextStyle": "@bgTxtStyle",
    "backgroundColorTop": "@bgColorTop",
    "backgroundColorBottom": "@bgColorBottom",
    "app-plus": {
      "titleNView": false,
      "bounce": "none"
    },
    "navigationStyle": "custom",
    "enablePullDownRefresh": false,
    "disableScroll": true
  },
  "pages": [
    // GENERATED BY UNI-PAGES, PLATFORM: H5 || MP-WEIXIN
    {
      "path": "pages/home/index",
      "type": "home",
      "layout": "home"
    },
    {
      "path": "pages/webview",
      "type": "page"
    },
    {
      "path": "pages/home/detail",
      "type": "page",
      "layout": "custom"
    },
    {
      "path": "pages/mine/index",
      "type": "page",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "个人中心"
      }
    },
    {
      "path": "pages/post/index",
      "type": "page",
      "layout": "home",
      "style": {
        "navigationBarTitleText": "发布"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub",
      "pages": [
        // GENERATED BY UNI-PAGES, PLATFORM: H5 || MP-WEIXIN
        {
          "path": "index",
          "type": "page"
        }
      ]
    },
    {
      "root": "sub-packages",
      "pages": [
        // GENERATED BY UNI-PAGES, PLATFORM: H5 || MP-WEIXIN
        {
          "path": "index",
          "type": "page"
        }
      ]
    }
  ],
  "tabBar": {
    "custom": true,
    "color": "#86909c",
    "selectedColor": "#165DFF",
    "list": [
      // GENERATED BY UNI-PAGES, PLATFORM: H5 || MP-WEIXIN
      {
        "pagePath": "pages/home/index",
        "iconPath": "static/tabbar/placeholder.png",
        "selectedIconPath": "static/tabbar/placeholder.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/mine/index",
        "iconPath": "static/tabbar/placeholder.png",
        "selectedIconPath": "static/tabbar/placeholder.png",
        "text": "我的"
      }
    ]
  }
}
